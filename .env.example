# GitHub — https://github.com/settings/tokens (repo scope)
VITE_GITHUB_TOKEN=
VITE_GITHUB_OWNER=your-org
VITE_GITHUB_REPO=your-repo
VITE_GITHUB_USERNAME=your-github-username

# Jira — https://id.atlassian.com/manage-profile/security/api-tokens
VITE_JIRA_DOMAIN=yourcompany.atlassian.net
VITE_JIRA_EMAIL=you@yourcompany.com
VITE_JIRA_TOKEN=
VITE_JIRA_PROJECT=DIG

# Confluence (can share Jira token if same Atlassian account)
VITE_CONFLUENCE_DOMAIN=yourcompany.atlassian.net
VITE_CONFLUENCE_EMAIL=you@yourcompany.com
VITE_CONFLUENCE_TOKEN=
VITE_CONFLUENCE_SPACE=ENG

# Microsoft Graph — https://portal.azure.com (Calendar.Read scope)
VITE_MS_GRAPH_TOKEN=

# Slack — https://api.slack.com/apps (user token with im:read, im:history,
# mpim:read, mpim:history scopes)
VITE_SLACK_TOKEN=
